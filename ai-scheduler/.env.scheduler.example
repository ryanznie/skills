## Zoom Server-to-Server OAuth (required to auto-create the meeting)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

## AgentMail (required to send the invite email + .ics)
AGENTMAIL_API_KEY=
## This is the AgentMail inbox id used as the From/host email address
AGENTMAIL_INBOX_ID=
## Optional: set the AgentMail inbox display name (affects the From display name recipients see)
AGENTMAIL_INBOX_DISPLAY_NAME=
## Optional: host name shown in the email body + .ics (defaults to AGENTMAIL_INBOX_DISPLAY_NAME if set)
AGENTMAIL_HOST_NAME=
## Optional: always CC this email address on every invite (comma-separated list supported)
AGENTMAIL_HOST=
## Required: subject prefix used in email subject (example: "Ryan +")
AGENTMAIL_SUBJECT_PREFIX=
