## Zoom Server-to-Server OAuth (required to auto-create the meeting)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

## AgentMail (required to send the invite email + .ics)
AGENTMAIL_API_KEY=
## This is the AgentMail inbox id used as the From email address
AGENTMAIL_INBOX_ID=
## Optional: host email shown in the email body + used as the .ics organizer (defaults to AGENTMAIL_INBOX_ID)
AGENTMAIL_HOST=
## Required: subject prefix used in email subject (example: "Ryan +")
AGENTMAIL_SUBJECT_PREFIX=
